  "rtl_strategy": {
    "method": "dir_attribute",
    "selector": "[dir=\"rtl\"] .inline-alert",
    "note": "RTL is handled via CSS logical properties and [dir='rtl'] selectors. No separate modifier class is needed."
  },
  "mobile_strategy": {
    "css_modifier": "inline-alert--mobile",
    "breakpoint": "max-width: 768px",
    "layout_changes": [
      "Header becomes flex-column",
      "Close button repositioned to absolute inset-inline-end: -8px",
      "Action buttons become full-width (align-self: stretch)",
      "Action buttons enlarge to height: 40px (lg size)"
    ]
  },
  "discarded_axes": [
    {
      "axis": "rtl_class",
      "reason": "RTL produces only layout direction changes achievable via CSS logical properties and [dir='rtl'] attribute selectors. No standalone CSS modifier class is needed."
    }
  ],
  "anatomy": {
