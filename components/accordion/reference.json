{
  "schema_version": "2.0.0",
  "component": {
    "name": "accordion",
    "description": "Accordion component with expandable content sections and interactive states."
  },
  "axes": ["variant", "expanded", "state", "size"],
  "axis_values": {
    "variant": ["normal", "flush", "leading", "leading-flush"],
    "expanded": [false, true],
    "state": ["default", "hovered", "focused", "pressed", "disabled"],
    "size": ["large", "medium", "small"]
  },
  "source_files": {
    "normal": {
      "expanded-false": "_figma/normal/expanded-false/",
      "expanded-true":  "_figma/normal/expanded-true/"
    },
    "flush": {
      "expanded-false": "_figma/flush/expanded-false/",
      "expanded-true":  "_figma/flush/expanded-true/"
    },
    "leading": {
      "expanded-false": "_figma/leading/expanded-false/",
      "expanded-true":  "_figma/leading/expanded-true/"
    },
    "leading-flush": {
      "expanded-false": "_figma/leading-flush/expanded-false/",
      "expanded-true":  "_figma/leading-flush/expanded-true/"
    }
  },
  "size_files": {
    "medium": "sizes/meduim/",
    "small":  "sizes/small/"
  },
  "list_file": "list/list.json",
  "css_class": {
    "base": ".accordion",
    "list": ".accordion-list (wraps multiple .accordion items, adds border-bottom)",
    "variant": ".accordion--{variant}",
    "size": ".accordion--{size} (large is default, no modifier)",
    "expanded": ".is-expanded (on root)",
    "state": {
      "hovered":  ".accordion__header.is-hovered",
      "focused":  ".accordion__header.is-focused",
      "pressed":  ".accordion__header.is-pressed",
      "disabled": ".accordion--disabled (on root)"
    }
  },
  "tokens": {
    "normal": {
      "border-color":  "var(--accordion-normal-border-color)",
      "title-color":   "var(--accordion-normal-title-color)",
      "content-color": "var(--accordion-normal-content-color)",
      "bg-hover":      "var(--accordion-normal-bg-hover)",
      "bg-pressed":    "var(--accordion-normal-bg-pressed)",
      "focus-ring":    "var(--accordion-normal-focus-ring)",
      "disabled-text": "var(--accordion-normal-disabled-text)"
    },
    "flush": "inherits all tokens from normal — only padding differs",
    "size": "size modifier only affects header padding-block; all other tokens are shared"
  },
