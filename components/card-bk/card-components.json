  "header": {
    "figmaNodeId": "30057:12136",
    "title": "Card",
    "description": "A card serves as a container for information and actions related to a specific concept or object. It typically resembles a rectangular box that combines images, text, and potentially some interactive elements. Cards enhance the visibility of information and facilitate predictable patterns.",
    "style": {
      "width": 2650,
      "height": 518,
      "variant": "ColorDark"
    }
  },
  "tokens": {
    "colors": {
      "surface": "#FFFFFF",
      "featuredIcon": "#161616",
      "textTitle": "#1F2A37",
      "textBody": "#1F2A37",
      "border": "#D2D6DB",
      "focusRing": "#9747FF"
    },
    "typography": {
      "fontFamily": "IBM Plex Sans Arabic",
      "cardTitle": {
        "fontSize": 18,
        "lineHeight": 28,
        "fontWeight": 700
      },
      "cardContent": {
        "fontSize": 16,
        "lineHeight": 24,
        "fontWeight": 400
      }
    },
    "radius": {
      "card": 16
    },
    "spacing": {
      "padding": 16,
      "sectionGap": 24,
      "contentGap": 8,
      "actionGap": 16
    },
    "shadow": {
      "withShadow": "0px 4px 8px -2px rgba(16,24,40,0.1), 0px 2px 4px -2px rgba(16,24,40,0.06)"
    },
    "featuredIcon": {
      "width": 48,
      "height": 48,
      "style": "Stroke / Rounded"
    }
  },
  "propertyAxes": {
    "RTL": {
      "values": [
        "no",
        "yes"
      ],
      "description": "Reading direction (Arabic = yes / RTL)."
    },
    "type": {
      "values": [
        "Default",
        "Expandable",
        "Selectable"
      ],
      "description": "Default = two action buttons; Expandable = single icon/expand action; Selectable = checkbox."
    },
    "state": {
      "values": [
        "Default",
        "Hover",
        "Focused",
        "Disabled"
      ]
    },
    "effect": {
      "values": [
        "With Shadow",
        "No Shadow",
        "Stroke"
      ],
      "description": "Card elevation / container treatment."
    },
    "expanded": {
      "values": [
        true,
        false
      ],
      "description": "Only meaningful for Expandable type."
    },
    "selected": {
      "values": [
        true,
        false
      ],
      "description": "Only meaningful for Selectable type."
    }
  },
  "effectStyles": {
    "With Shadow": {
      "boxShadow": "0px 4px 8px -2px rgba(16,24,40,0.1), 0px 2px 4px -2px rgba(16,24,40,0.06)",
      "border": "none"
    },
    "No Shadow": {
      "boxShadow": "none",
      "border": "none"
    },
    "Stroke": {
      "boxShadow": "none",
      "border": "1px solid #D2D6DB"
    }
  },
  "stateStyles": {
    "Default": {
      "description": "Resting state."
    },
    "Hover": {
      "description": "Pointer hovering; subtle surface/border emphasis."
    },
    "Focused": {
      "description": "Keyboard focus; 1px focus ring #9747FF.",
      "focusRing": "#9747FF"
    },
    "Disabled": {
      "description": "Non-interactive; muted greys, reduced opacity.",
      "opacity": 0.5
    }
  },
  "typeAnatomy": {
    "Default": {
      "slots": [
        "featuredIcon",
        "content(title+body)",
        "actions(2 buttons)"
      ],
      "baseSize": {
        "width": 360,
        "height": 228
      }
    },
    "Expandable": {
      "slots": [
        "featuredIcon",
        "content(title+body)",
        "actions(icon button, bottom-end)"
      ],
      "baseSize": {
        "width": 360,
        "height": 228
      },
      "note": "Height grows when Expanded=true."
    },
    "Selectable": {
      "slots": [
        "featuredIcon",
        "content(title+body)",
        "checkbox(top-end)"
      ],
      "baseSize": {
        "width": 360,
        "height": 164
      }
    }
  },
