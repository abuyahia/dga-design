{
  "schema_version": "2.0.0",
  "component": {
    "name": "text-input",
    "description": "Base text input field with label, supporting six interactive states, two sizes, error mode, and three background styles."
  },
  "axes": ["state", "size", "error", "style"],
  "axis_values": {
    "state": ["default", "hovered", "focused", "pressed", "disabled", "read-only"],
    "size": ["large", "medium"],
    "error": [false, true],
    "style": ["default", "filled-darker", "filled-lighter"]
  },
  "discarded_axes": [
    {
      "axis": "RTL",
      "reason": "CSS logical properties (padding-inline-start, padding-inline-end) produce identical output for LTR and RTL. RTL is triggered by dir='rtl' on an ancestor element. No separate CSS class or modifier needed."
    },
    {
      "axis": "Filled",
      "reason": "Filled=True/False represents whether the user has entered text. This is a runtime browser state handled by <input>::placeholder CSS. Both Filled values share identical field CSS. No modifier class needed."
    }
  ],
  "size_tokens": {
    "large": {
      "height": "var(--text-input-lg-height, 40px)",
      "font-size": "var(--text-input-lg-font-size, 16px)",
      "line-height": "var(--text-input-lg-line-height, 24px)",
      "css-modifier": null
    },
    "medium": {
