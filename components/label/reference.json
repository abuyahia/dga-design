  "implementation_notes": [
    "Default (no modifier) = Medium size, Regular type.",
    "RTL: dir='rtl' on the label element or ancestor. DOM child order [.label__required, .label__text] is constant — inline-flex reversal handles visual order.",
    "Disabled: .label--disabled class + aria-disabled='true'. The <label> element has no native :disabled pseudo-class.",
    "Required asterisk (.label__required) is optional. Omit when the field is not required.",
    "aria-required='true' must be set on the associated form control, not on the <label> itself.",
    "The <label> must be linked to its form control via for='field-id' or by nesting the control inside the label."
  ]
}
